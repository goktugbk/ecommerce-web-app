generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String

  firstName String
  lastName  String
  phone     String

  role      Role     @default(CUSTOMER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  defaultAddressId String?
  defaultAddress   Address? @relation(name: "UserDefaultAddress", fields: [defaultAddressId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  addresses Address[] @relation("UserAddresses")

  sessions Session[]
  Cart     Cart?
  Order    Order[]
  reviews  Review[]

  audits   AdminAudit[] @relation("AdminAuditsByAdmin")

  @@index([defaultAddressId])
}

model Address {
  id     String @id @default(cuid())
  userId String

  // Kullanıcı -> Adresler (1-N) ilişkisi
  user User @relation("UserAddresses", fields: [userId], references: [id], onDelete: Cascade)

  // Kullanıcı -> defaultAddress (1-1 opsiyonel) geri referans
  usersDefaultFor User[] @relation("UserDefaultAddress")

  fullName   String
  phone      String
  line1      String
  line2      String?
  district   String
  city       String
  postalCode String
  country    String @default("TR")
  label      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

/// *
// * ---------- Category ----------
model Category {
  id           String    @id @default(cuid())
  name         String
  slug         String    @unique
  homeFeatured Boolean   @default(false)
  homeOrder    Int       @default(0)
  imageUrl     String?
  products     Product[]

  @@index([homeFeatured, homeOrder])
}

model Product {
  id            String           @id @default(cuid())
  title         String
  slug          String           @unique
  description   String?
  price         Decimal          @db.Decimal(10, 2)
  currency      String           @default("TRY")
  categoryId    String?
  isActive      Boolean          @default(true)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  featuredOrder Int              @default(0)
  isFeatured    Boolean          @default(false)
  CartItem      CartItem[]
  inventory     Inventory?
  OrderItem     OrderItem[]
  category      Category?        @relation(fields: [categoryId], references: [id])
  images        ProductImage[]
  variants      ProductVariant[]
  reviews       Review[]
}

model ProductImage {
  id        String  @id @default(cuid())
  url       String
  alt       String?
  productId String
  isPrimary Boolean @default(false)
  isHover   Boolean @default(false)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductVariant {
  id        String  @id @default(cuid())
  name      String
  sku       String  @unique
  price     Decimal @db.Decimal(10, 2)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Review {
  id        String   @id @default(cuid())
  productId String
  userId    String
  rating    Int      @default(0)
  comment   String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([productId, userId])
  @@index([productId, createdAt])
}

model Inventory {
  id                String  @id @default(cuid())
  productId         String  @unique
  quantity          Int     @default(0)
  lowStockThreshold Int     @default(3)
  product           Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Cart {
  id        String  @id @default(cuid())
  userId    String? @unique
  sessionId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User?      @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  items CartItem[]

  checkoutSessions CheckoutSession[] @relation("CartCheckoutSessions")

  @@index([createdAt])
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  productId String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  unitPrice Decimal? @db.Decimal(10, 2)

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  // Aynı ürünü aynı sepete ikinci kez eklemeyi engeller (upsert için gerekli)
  @@unique([cartId, productId], name: "cartId_productId")
  @@index([createdAt])
}

model ShippingMethod {
  id       String  @id @default(cuid())
  code     String  @unique
  name     String
  fee      Decimal @default(0) @db.Decimal(10, 2)
  isActive Boolean @default(true)
}

model PaymentMethod {
  id       String  @id @default(cuid())
  code     String  @unique
  name     String
  isActive Boolean @default(true)
}

model Order {
  id          String      @id @default(cuid())
  userId      String?
  totalAmount Decimal     @db.Decimal(10, 2)
  currency    String      @default("TRY")
  status      OrderStatus @default(PENDING)
  paymentId   String?
  shipmentId  String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  orderCode String @unique // sipariş kodu

  // İlişkiler
  user     User?       @relation(fields: [userId], references: [id])
  items    OrderItem[]
  Shipment Shipment?

  // ---------- SNAPSHOT: Sipariş anındaki müşteri & adres bilgileri ----------
  // Müşteri iletişim (guest için veya override)
  contactName  String?
  contactEmail String?
  contactPhone String?

  // Teslimat (shipping) adresi
  shipFirstName String?
  shipLastName  String?
  shipPhone     String?
  shipEmail     String?
  shipLine1     String?
  shipLine2     String?
  shipDistrict  String? // ilçe/semt
  shipCity      String?
  shipPostal    String?
  shipCountry   String?

  // Fatura (billing) adresi - opsiyonel
  billFirstName String?
  billLastName  String?
  billPhone     String?
  billEmail     String?
  billLine1     String?
  billLine2     String?
  billDistrict  String?
  billCity      String?
  billPostal    String?
  billCountry   String?

  @@index([userId])
  @@index([createdAt])
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  unitPrice Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())

  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([productId])
}

model HeroSlide {
  id            String   @id @default(cuid())
  title         String
  subtitle      String?
  imageUrl      String
  mobileImageUrl String?
  buttons       Json?
  isActive      Boolean  @default(true)
  startsAt      DateTime?
  endsAt        DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  order     Int? 
}


model AdminAudit {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  entity    String?
  entityId  String?
  message   String?
  meta      Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  admin User @relation("AdminAuditsByAdmin", fields: [adminId], references: [id])

  @@index([adminId])
  @@index([entity, entityId])
  @@map("AdminAudit")
}


enum Role {
  ADMIN
  CUSTOMER
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELED
}

enum CheckoutStatus {
  PENDING
  COMPLETED
  CANCELED
  EXPIRED
}

model CheckoutSession {
  id     String @id @default(cuid()) // checkout URL'inde kullanılacak rastgele ID
  cartId String
  // İlişki: Cart ile adlandırılmış relation (geri taraf Cart.checkoutSessions)
  cart   Cart   @relation("CartCheckoutSessions", fields: [cartId], references: [id], onDelete: Cascade)

  status    CheckoutStatus @default(PENDING)
  createdAt DateTime       @default(now())
  expiresAt DateTime

  // opsiyonel iz bilgileri
  clientIp  String?
  userAgent String?

  @@index([cartId, status])
}

model Shipment {
  id        String   @id @default(cuid())
  orderId   String   @unique
  carrier   String
  tracking  String?
  labelUrl  String?
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([userId])
}
